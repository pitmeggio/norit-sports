---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { t, path, COMPANY, CLOUDFLARE_ANALYTICS_TOKEN, type Lang, type RouteKey } from "../i18n/content";

interface Props {
  lang: Lang;
  current: RouteKey;
  ogImage?: string;
  title?: string;
  description?: string;
}
const { lang, current, ogImage = "/images/hero.webp", title, description } = Astro.props;
const tr = t[lang];
const defaultMeta = tr.meta[current];
const meta = {
  title: title ?? defaultMeta.title,
  description: description ?? defaultMeta.description,
};

const site = Astro.site ?? new URL("https://www.norit-sports.no");
const canonical = new URL(path(lang, current), site).href;
const noUrl = new URL(path("no", current), site).href;
const enUrl = new URL(path("en", current), site).href;
const ogImageUrl = new URL(ogImage, site).href;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: COMPANY.name,
  url: site.href,
  email: COMPANY.email,
  telephone: COMPANY.phone,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Tenåsvegen 184",
    postalCode: "2432",
    addressLocality: "Slettås",
    addressCountry: "NO",
  },
  description: meta.description,
};
---

<!doctype html>
<html lang={lang === "no" ? "nb" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/images/logo-n.webp" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="nb" href={noUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={noUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Norit Sports" />
    <meta property="og:locale" content={lang === "no" ? "nb_NO" : "en_US"} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Inter+Tight:wght@600;700;800;900&family=JetBrains+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

    <ClientRouter />
  </head>
  <body>
    <Header lang={lang} current={current} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    {
      CLOUDFLARE_ANALYTICS_TOKEN && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${CLOUDFLARE_ANALYTICS_TOKEN}"}`}
        />
      )
    }

    <script>
      // Per-page lifecycle: re-bind on every navigation (initial + ClientRouter swaps).
      // Document/window listeners use an AbortController so we don't double-bind.
      let pageAbort: AbortController | null = null;

      function init() {
        pageAbort?.abort();
        pageAbort = new AbortController();
        const signal = pageAbort.signal;
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        // ---- Reveal on scroll
        const reveals = document.querySelectorAll("[data-reveal]");
        if (reduce || !("IntersectionObserver" in window)) {
          reveals.forEach((el) => el.classList.add("is-visible"));
        } else {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  io.unobserve(entry.target);
                }
              });
            },
            { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
          );
          reveals.forEach((el) => io.observe(el));
        }

        // ---- Progressive image loading (runs for everyone; opacity-only)
        document.querySelectorAll<HTMLImageElement>('img[loading="lazy"]').forEach((img) => {
          if (img.complete) return;
          img.classList.add("lz");
          img.addEventListener("load", () => img.classList.add("lz-in"), { once: true, signal });
          img.addEventListener("error", () => img.classList.add("lz-in"), { once: true, signal });
        });

        // ---- Lazy application videos (runs for everyone; autoplay only without reduced motion)
        document.querySelectorAll<HTMLElement>("[data-video-embed]").forEach((box) => {
          const iframe = box.querySelector<HTMLIFrameElement>("iframe[data-yt]");
          const id = box.dataset.videoId;
          if (!iframe || !id) return;
          const send = (func: string) =>
            iframe.contentWindow?.postMessage(JSON.stringify({ event: "command", func, args: [] }), "*");
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  if (!iframe.src) {
                    const autoplay = reduce ? 0 : 1;
                    iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=${autoplay}&mute=1&playsinline=1&rel=0&enablejsapi=1`;
                  } else if (!reduce) {
                    send("playVideo");
                  }
                } else if (iframe.src && !reduce) {
                  send("pauseVideo");
                }
              });
            },
            { threshold: 0.35 }
          );
          io.observe(box);
        });

        if (reduce) return;


        // ---- Animated counters: any element with data-count
        const counters = document.querySelectorAll<HTMLElement>("[data-count]");
        if (counters.length) {
          const cio = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                const el = entry.target as HTMLElement;
                const target = parseInt(el.dataset.count || "0", 10);
                const suffix = el.dataset.suffix || "";
                const start = performance.now();
                const duration = 1300;
                const animate = (now: number) => {
                  const t = Math.min(1, (now - start) / duration);
                  const eased = 1 - Math.pow(1 - t, 3);
                  el.textContent = Math.round(eased * target) + suffix;
                  if (t < 1) requestAnimationFrame(animate);
                };
                el.textContent = "0" + suffix;
                requestAnimationFrame(animate);
                cio.unobserve(el);
              });
            },
            { threshold: 0.5 }
          );
          counters.forEach((el) => cio.observe(el));
        }

        // ---- Hero parallax (immersive hero image drifts slower than scroll)
        const heroImg = document.querySelector<HTMLElement>(".hero-im__media img");
        if (heroImg) {
          const updateParallax = () => {
            const y = Math.min(window.scrollY, 900);
            heroImg.style.setProperty("--py", y * 0.22 + "px");
          };
          window.addEventListener("scroll", updateParallax, { passive: true, signal });
          updateParallax();
        }

        // ---- Light generic parallax on marked media (transform-only, rAF throttled)
        const pEls = Array.from(document.querySelectorAll<HTMLElement>("[data-parallax]"));
        if (pEls.length) {
          let ticking = false;
          const tickParallax = () => {
            ticking = false;
            const vh = window.innerHeight;
            for (const el of pEls) {
              const r = el.getBoundingClientRect();
              if (r.bottom < -80 || r.top > vh + 80) continue;
              const progress = (r.top + r.height / 2 - vh / 2) / vh; // -0.5..0.5 around center
              const y = Math.max(-36, Math.min(36, progress * -44));
              el.style.transform = `translate3d(0, ${y.toFixed(1)}px, 0) scale(1.1)`;
            }
          };
          const onScrollP = () => {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(tickParallax);
            }
          };
          window.addEventListener("scroll", onScrollP, { passive: true, signal });
          tickParallax();
        }


        // ---- Magnetic buttons (data-magnetic)
        document.querySelectorAll<HTMLElement>("[data-magnetic]").forEach((btn) => {
          btn.addEventListener(
            "mousemove",
            (e) => {
              const rect = btn.getBoundingClientRect();
              const x = e.clientX - rect.left - rect.width / 2;
              const y = e.clientY - rect.top - rect.height / 2;
              btn.style.transform = `translate(${x * 0.22}px, ${y * 0.4}px)`;
            },
            { signal }
          );
          btn.addEventListener(
            "mouseleave",
            () => {
              btn.style.transform = "";
            },
            { signal }
          );
        });

      }

      document.addEventListener("astro:page-load", init);
    </script>
  </body>
</html>
