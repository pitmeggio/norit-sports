---
import { t, path, type Lang, type RouteKey } from "../i18n/content";
import { MAPLUS_LINE_DEFS, EFB_LINE_DEFS, lineTitle } from "../data/lines";

interface Props {
  lang: Lang;
  current: RouteKey;
}
const { lang, current } = Astro.props;
const tr = t[lang];

const simpleLinks: { key: RouteKey; label: string }[] = [
  { key: "videos", label: tr.nav.videos },
  { key: "retail", label: tr.nav.retail },
  { key: "partner", label: tr.nav.partner },
  { key: "contact", label: tr.nav.contact },
];

const maplusBase = `${path(lang, "maplus")}/${lang === "no" ? "produkter" : "products"}`;
const efbBase = `${path(lang, "efb")}/${lang === "no" ? "produkter" : "products"}`;

const brandsActive =
  current === "brands" || current === "maplus" || current === "efb";

const T = {
  no: { all: "Alle produkter", about: "Om merket", explore: "Utforsk" },
  en: { all: "All products", about: "About the brand", explore: "Explore" },
}[lang];
---

<header class="site-header">
  <div class="container container--wide site-header__inner">
    <a class="brand" href={path(lang, "home")}>Norit <span>Sports</span></a>

    <button class="nav-toggle" aria-label="Menu" aria-expanded="false" data-nav-toggle>
      <span></span><span></span><span></span>
    </button>

    <nav class="nav" id="primary-nav">
      <!-- Merker: link + Db-style mega panel on hover -->
      <div class="nav-item nav-item--mega">
        <a href={path(lang, "brands")} aria-current={brandsActive ? "page" : undefined} aria-haspopup="true">
          {tr.nav.brands}
        </a>

        <div class="mega" role="region" aria-label={tr.nav.brands}>
          <div class="container container--wide mega__inner">
            <div class="mega__col">
              <p class="mega__heading">MAPLUS</p>
              <ul class="mega__list">
                <li><a class="mega__all" href={maplusBase}>{T.all}</a></li>
                {
                  MAPLUS_LINE_DEFS.map((l) => (
                    <li>
                      <a href={`${maplusBase}?line=${l.handle}`}>{lineTitle(l, lang)}</a>
                    </li>
                  ))
                }
                <li><a class="mega__about" href={path(lang, "maplus")}>{T.about} →</a></li>
              </ul>
            </div>

            <div class="mega__col">
              <p class="mega__heading">EFB Sport</p>
              <ul class="mega__list">
                <li><a class="mega__all" href={efbBase}>{T.all}</a></li>
                {
                  EFB_LINE_DEFS.map((l) => (
                    <li>
                      <a href={`${efbBase}?line=${l.handle}`}>{lineTitle(l, lang)}</a>
                    </li>
                  ))
                }
                <li><a class="mega__about" href={path(lang, "efb")}>{T.about} →</a></li>
              </ul>
            </div>

            <div class="mega__promos">
              <a class="mega__promo" href={path(lang, "maplus")}>
                <img src="/images/maplus/iron.jpg" alt="" loading="lazy" />
                <span class="mega__promo-text">
                  <strong>MAPLUS</strong>
                  <span>{T.explore} →</span>
                </span>
              </a>
              <a class="mega__promo" href={path(lang, "efb")}>
                <img src="/images/efb/insoles-hero.jpg" alt="" loading="lazy" />
                <span class="mega__promo-text">
                  <strong>EFB Sport</strong>
                  <span>{T.explore} →</span>
                </span>
              </a>
            </div>
          </div>
        </div>
      </div>

      {
        simpleLinks.map((l) => (
          <a href={path(lang, l.key)} aria-current={current === l.key ? "page" : undefined}>
            {l.label}
          </a>
        ))
      }
      <span class="lang" aria-label="Language">
        <a href={path("no", current)} aria-current={(lang === "no").toString()}>NO</a>
        <span aria-hidden="true">/</span>
        <a href={path("en", current)} aria-current={(lang === "en").toString()}>EN</a>
      </span>
    </nav>
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const toggle = document.querySelector("[data-nav-toggle]");
    const nav = document.getElementById("primary-nav");
    toggle?.addEventListener("click", () => {
      const open = nav?.getAttribute("data-open") === "true";
      nav?.setAttribute("data-open", (!open).toString());
      toggle.setAttribute("aria-expanded", (!open).toString());
    });

    // Close mega on Escape (hover/focus handled in CSS)
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") (document.activeElement as HTMLElement | null)?.blur();
    });
  });
</script>
