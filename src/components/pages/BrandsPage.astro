---
import Base from "../../layouts/Base.astro";
import PageHero from "../PageHero.astro";
import MaplusLinesGrid from "../MaplusLinesGrid.astro";
import { t, path, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const b = tr.brandsIndex;

const efbBase = `${path(lang, "efb")}/${lang === "no" ? "produkter" : "products"}`;
const efbLines = [
  { title: tr.efb.catInsoles, img: "/images/efb/boots-insoles.jpg", href: `${efbBase}?line=insoles` },
  { title: tr.efb.catAccessories, img: "/images/efb/cat-tracks.jpg", href: `${efbBase}?line=accessories` },
  { title: tr.efb.catLab, img: "/images/efb/boot-stretcher.jpg", href: `${efbBase}?line=workshop` },
];
---

<Base lang={lang} current="brands">
  <PageHero
    eyebrow={b.kicker}
    title={b.title}
    lead={b.intro}
    metaLeft={lang === "no" ? "TO MERKER · ÉN PARTNER" : "TWO BRANDS · ONE PARTNER"}
    metaRight={lang === "no" ? "DISTRIBUSJON I NORDEN" : "DISTRIBUTION IN THE NORDICS"}
  />

  <!-- ── MAPLUS: brand header + official line grid ─────────────── -->
  <section class="section" style="padding-top:0;">
    <div class="container container--wide">
      <div class="brand-head" data-reveal>
        <div class="brand-head__left">
          <div class="brand-head__logo">
            <img src="/images/maplus-logo.webp" alt="MAPLUS" loading="lazy" />
          </div>
          <p class="brand-head__blurb">{b.maplusBlurb}</p>
        </div>
        <a class="brand-head__link" href={path(lang, "maplus")}>
          {lang === "no" ? "Om merket" : "About the brand"}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <MaplusLinesGrid lang={lang} />
    </div>
  </section>

  <!-- ── EFB SPORT: brand header + categories ──────────────────── -->
  <section class="section" style="background: var(--paper-2);">
    <div class="container container--wide">
      <div class="brand-head" data-reveal>
        <div class="brand-head__left">
          <div class="brand-head__logo">
            <img src="/images/efb/logo.webp" alt="EFB Sport" loading="lazy" />
          </div>
          <p class="brand-head__blurb">{b.efbBlurb}</p>
        </div>
        <a class="brand-head__link" href={path(lang, "efb")}>
          {lang === "no" ? "Om merket" : "About the brand"}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="line-grid">
        {
          efbLines.map((l, i) => (
            <a class="line-card" href={l.href} data-reveal style={`--reveal-delay:${i * 70}ms;`}>
              <div class="line-card__media">
                <img src={l.img} alt={l.title} loading="lazy" />
              </div>
              <div class="line-card__body">
                <h3 class="line-card__title">{l.title}</h3>
                <span class="line-card__arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>
