---
import Base from "../../layouts/Base.astro";
import { t, path, type Lang } from "../../i18n/content";
import { findProduct, productsByBrand, type ProductBrand } from "../../data/products";
import { findProductVideo } from "../../data/videos";

interface Props {
  lang: Lang;
  brand: ProductBrand;
  slug: string;
}
const { lang, brand, slug } = Astro.props;
const tr = t[lang];

const product = findProduct(brand, slug);
if (!product) {
  return Astro.redirect(path(lang, brand));
}
const brandName = brand === "maplus" ? "MAPLUS" : "EFB Sport";

// Suggest 4 related products from same line
const related = productsByBrand(brand)
  .filter((p) => p.lineHandle === product.lineHandle && p.slug !== product.slug)
  .slice(0, 4);

const T = {
  no: {
    backToList: "Tilbake til produktene",
    askInfo: "Be om info / pris",
    askInfoSub: "Vi svarer raskt. Beskriv mengde og bruk hvis aktuelt.",
    line: "Serie",
    type: "Type",
    brand: "Merke",
    format: "Format",
    code: "Kode",
    techSpecs: "Tekniske spesifikasjoner",
    related: "Andre produkter i samme serie",
    description: "Beskrivelse",
  },
  en: {
    backToList: "Back to products",
    askInfo: "Request info / price",
    askInfoSub: "We reply quickly. Mention quantity or use case if relevant.",
    line: "Line",
    type: "Type",
    brand: "Brand",
    format: "Format",
    code: "Code",
    techSpecs: "Technical specifications",
    related: "More from the same line",
    description: "Description",
  },
}[lang];

const contactUrl = `${path(lang, "contact")}?product=${encodeURIComponent(product.title)}&brand=${brand}`;

// Application photo per line: shows the product family in real use
const APPLY_IMG: Record<string, string> = {
  // MAPLUS
  "maplus:xcelerate": "/images/maplus/powder-pour.jpg",
  "maplus:gm": "/images/maplus/wax-blocks.jpg",
  "maplus:bp10": "/images/maplus/iron-drip.jpg",
  "maplus:racing-base": "/images/maplus/iron.jpg",
  "maplus:xc-line": "/images/maplus/brush.jpg",
  "maplus:block-line": "/images/maplus/wax-blocks.jpg",
  "maplus:voks": "/images/maplus/iron-drip.jpg",
  "maplus:bike": "/images/bike-care.jpg",
  "maplus:textile": "/images/textile-care.jpg",
  "maplus:accessori": "/images/maplus/iron-scrape.jpg",
  // EFB
  "efb:insoles": "/images/efb/boots-insoles.jpg",
  "efb:accessories": "/images/efb/cat-tracks.jpg",
  "efb:workshop": "/images/efb/workshop.jpg",
  "efb:apparel": "/images/efb/hero.webp",
};
const applyImg = APPLY_IMG[`${brand}:${product.lineHandle}`];
const applyLabel = lang === "no" ? "I bruk" : "In use";

const videoId = findProductVideo(product);
const videoTitle = lang === "no" ? "Bruksvideo" : "Application video";
---

<Base lang={lang} current={brand} title={`${product.title} | ${brandName} | Norit Sports`} description={product.desc.slice(0, 160) || `${product.title} — ${product.lineTitle} — ${brandName}.`} ogImage={product.image ?? "/images/hero.webp"}>
  <article class="prod-detail">
    <div class="container container--wide">
      <!-- Breadcrumb -->
      <nav class="prod-breadcrumb">
        <a href={path(lang, brand)}>{brandName}</a>
        <span aria-hidden="true">›</span>
        <a href={`${path(lang, brand)}/${lang === "no" ? "produkter" : "products"}`}>{lang === "no" ? "Produkter" : "Products"}</a>
        <span aria-hidden="true">›</span>
        <span class="prod-breadcrumb__current">{product.title}</span>
      </nav>

      <div class="prod-detail__grid">
        <!-- Media -->
        <figure class="prod-detail__media" data-reveal>
          {
            product.image ? (
              <img src={product.image} alt={product.title} fetchpriority="high" />
            ) : (
              <span class="prod-card__noimg">{brandName}</span>
            )
          }
        </figure>

        <!-- Info -->
        <div class="prod-detail__info" data-reveal style="--reveal-delay:120ms;">
          <span class="eyebrow">{product.lineTitle}</span>
          <h1 class="prod-detail__title">{product.title}</h1>

          {product.desc && <p class="lead prod-detail__desc">{product.desc}</p>}

          <!-- Technical specs (factual product data from the manufacturer) -->
          {
            product.specs.length > 0 && (
              <div class="prod-techspecs">
                <p class="tech prod-techspecs__label">{T.techSpecs}</p>
                <dl class="prod-specs">
                  {product.specs.map((s) => (
                    <div>
                      <dt>{lang === "no" ? s.labelNo : s.labelEn}</dt>
                      <dd>{lang === "no" ? s.valueNo : s.valueEn}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )
          }

          <!-- Identity specs -->
          <dl class="prod-specs">
            <div>
              <dt>{T.brand}</dt>
              <dd>{brandName}</dd>
            </div>
            <div>
              <dt>{T.line}</dt>
              <dd>{product.lineTitle}</dd>
            </div>
            {
              product.format.length > 0 && (
                <div>
                  <dt>{T.format}</dt>
                  <dd>{product.format.join(" · ")}</dd>
                </div>
              )
            }
            {
              product.sku.length > 0 && (
                <div>
                  <dt>{T.code}</dt>
                  <dd>{product.sku.join(" · ")}</dd>
                </div>
              )
            }
          </dl>

          <!-- CTA -->
          <div class="prod-cta">
            <a class="btn btn--accent" href={contactUrl}>{T.askInfo}</a>
            <p class="tech prod-cta__sub">{T.askInfoSub}</p>
          </div>
        </div>
      </div>

      <!-- Application video: lazy, autoplays muted when scrolled into view -->
      {
        videoId && (
          <section class="prod-video" data-video-embed data-video-id={videoId} data-reveal>
            <p class="eyebrow">{videoTitle}</p>
            <div class="prod-video__frame">
              <iframe
                data-yt
                title={`${product.title} · ${videoTitle}`}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              />
            </div>
          </section>
        )
      }

      <!-- Application photo: the product family in real use -->
      {
        applyImg && (
          <figure class="prod-apply" data-reveal>
            <img src={applyImg} alt={`${product.lineTitle} ${applyLabel}`} loading="lazy" data-parallax />
            <figcaption>{brandName} · {applyLabel}</figcaption>
          </figure>
        )
      }

      <!-- Related products in same line -->
      {
        related.length > 0 && (
          <section class="prod-related">
            <p class="eyebrow">{T.related}</p>
            <div class="prod-grid prod-grid--related">
              {related.map((p) => (
                <a class="prod-card" href={`${path(lang, brand)}/${lang === "no" ? "produkter" : "products"}/${p.slug}`}>
                  <div class="prod-card__media">
                    {p.image ? (
                      <img src={p.image} alt={p.title} loading="lazy" />
                    ) : (
                      <span class="prod-card__noimg">{brandName}</span>
                    )}
                  </div>
                  <div class="prod-card__body">
                    <span class="tech prod-card__line">{p.lineTitle}</span>
                    <h3 class="prod-card__title">{p.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </article>
</Base>
