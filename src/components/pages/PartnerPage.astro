---
import Base from "../../layouts/Base.astro";
import PageHero from "../PageHero.astro";
import { t, path, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const p = tr.partner;
---

<Base lang={lang} current="partner">
  <PageHero
    eyebrow={p.kicker}
    title={p.kicker}
    lead={p.intro}
    metaLeft={lang === "no" ? "FOR MERKER · FOR LAG" : "FOR BRANDS · FOR TEAMS"}
    metaRight={lang === "no" ? "SKANDINAVIA" : "SCANDINAVIA"}
  />

  <section class="section" style="padding-top:0;">
    <div class="container container--wide">
      <div class="grid grid--2">
        <article class="brand-card" data-reveal>
          <div class="brand-card__photo">
            <img src="/images/generic.webp" alt="" loading="lazy" />
          </div>
          <div class="brand-card__body">
            <span class="tech">01 / 02</span>
            <h3 style="font-family:var(--font-display); font-size:clamp(1.5rem,2.4vw,2rem); letter-spacing:-0.02em;">{p.brandsTitle}</h3>
            <p class="brand-card__blurb">{p.brandsBody}</p>
            <ul class="ticks" style="margin-top:0.6rem;">
              {p.brandsPoints.map((pt) => <li>{pt}</li>)}
            </ul>
          </div>
        </article>

        <article class="brand-card" data-reveal style="--reveal-delay:130ms;">
          <div class="brand-card__photo">
            <img src="/images/ski-2.webp" alt="" loading="lazy" />
          </div>
          <div class="brand-card__body">
            <span class="tech">02 / 02</span>
            <h3 style="font-family:var(--font-display); font-size:clamp(1.5rem,2.4vw,2rem); letter-spacing:-0.02em;">{p.teamsTitle}</h3>
            <p class="brand-card__blurb">{p.teamsBody}</p>
            <ul class="ticks" style="margin-top:0.6rem;">
              {p.teamsPoints.map((pt) => <li>{pt}</li>)}
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Closing dark CTA -->
  <section class="closing">
    <img class="closing__bg" src="/images/ski-2.webp" alt="" loading="lazy" />
    <div class="container container--wide closing__inner">
      <div>
        <p class="eyebrow eyebrow--light" data-reveal>{lang === "no" ? "La oss snakke" : "Let's talk"}</p>
        <h2 class="closing__title" style="margin-top:1.6rem;" data-reveal>{tr.home.ctaTitle}</h2>
      </div>
      <div class="closing__aside" data-reveal style="--reveal-delay:120ms;">
        <a class="btn btn--accent" href={path(lang, "contact")}>{p.ctaButton}</a>
      </div>
    </div>
  </section>
</Base>
