---
import Base from "../../layouts/Base.astro";
import { t, path, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const p = tr.partner;
---

<Base lang={lang} current="partner">
  <section class="section">
    <div class="container">
      <p class="kicker" data-reveal>{p.kicker}</p>
      <h1 class="section-title" style="margin-top:0.6rem;" data-reveal>{p.kicker}</h1>
      <p class="lead" style="margin-top:1rem;" data-reveal>{p.intro}</p>

      <div class="grid grid--2" style="margin-top:3rem;">
        <article class="card" data-reveal>
          <img class="card__media" src="/images/generic.webp" alt={p.brandsTitle} loading="lazy" />
          <div class="card__body">
            <h3>{p.brandsTitle}</h3>
            <p>{p.brandsBody}</p>
            <ul class="ticks" style="margin-top:0.6rem;">
              {p.brandsPoints.map((pt) => <li>{pt}</li>)}
            </ul>
          </div>
        </article>

        <article class="card" data-reveal style="--reveal-delay:130ms;">
          <img class="card__media" src="/images/ski-2.webp" alt={p.teamsTitle} loading="lazy" />
          <div class="card__body">
            <h3>{p.teamsTitle}</h3>
            <p>{p.teamsBody}</p>
            <ul class="ticks" style="margin-top:0.6rem;">
              {p.teamsPoints.map((pt) => <li>{pt}</li>)}
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section bg-ink">
    <div class="container stack" style="max-width:720px;">
      <h2 class="section-title">{tr.home.ctaTitle}</h2>
      <p class="lead">{tr.home.ctaBody}</p>
      <a class="btn btn--accent" href={path(lang, "contact")}>{p.ctaButton}</a>
    </div>
  </section>
</Base>
