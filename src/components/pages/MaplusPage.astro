---
import Base from "../../layouts/Base.astro";
import { t, path, CATALOGS, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const m = tr.maplus;

const cats = [
  { title: m.catSki, desc: m.catSkiDesc, img: "/images/ski-1.webp", href: CATALOGS.ski, cta: m.downloadCatalog },
  { title: m.catBike, desc: m.catBikeDesc, img: "/images/bike-care.jpg", href: CATALOGS.bike, cta: m.downloadCatalog },
  { title: m.catTextile, desc: m.catTextileDesc, img: "/images/textile-care.jpg", href: CATALOGS.textile, cta: m.viewGuide },
];
---

<Base lang={lang} current="maplus">
  <section class="section">
    <div class="container">
      <p class="kicker" data-reveal>{m.kicker}</p>
      <h1 class="section-title" style="margin-top:0.6rem; max-width:14ch;" data-reveal>MAPLUS</h1>
      <p class="lead" style="margin-top:1rem;" data-reveal>{m.intro}</p>

      <div class="split split--offset" style="margin-top:clamp(2.5rem,5vw,4rem);">
        <div class="stack" data-reveal>
          <p class="kicker">{m.brandKicker}</p>
          <h2 class="section-title">{m.brandTitle}</h2>
          <p class="lead">{m.brandBody1}</p>
          <p style="color:var(--ink-soft); max-width:60ch;">{m.brandBody2}</p>

          <dl class="facts">
            {
              m.facts.map((f) => (
                <div class="fact">
                  <dt>{f.value}</dt>
                  <dd>{f.label}</dd>
                </div>
              ))
            }
          </dl>
        </div>

        <div class="split__media fx-mono" data-reveal style="--reveal-delay:120ms;">
          <img src="/images/hero.webp" alt="MAPLUS racing preparation" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-alt">
    <div class="container">
      <p class="kicker" data-reveal>{m.productsKicker}</p>
      <h2 class="section-title" style="margin-top:0.6rem;" data-reveal>{`${m.catSki} · ${m.catBike} · ${m.catTextile}`}</h2>

      <div class="grid grid--3" style="margin-top:2.5rem;">
        {
          cats.map((c, i) => (
            <a class="card card--link" href={c.href} target="_blank" rel="noopener" data-reveal style={`--reveal-delay:${i * 110}ms;`}>
              <div class="card__media-wrap">
                <img class="card__media fx-cover" src={c.img} alt={c.title} loading="lazy" />
                <span class="card__num">{String(i + 1).padStart(2, "0")}</span>
              </div>
              <div class="card__body">
                <h3>{c.title}</h3>
                <p>{c.desc}</p>
                <span class="card__cta">
                  {c.cta}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split split--offset">
      <div class="split__media" data-reveal>
        <img src="/images/racing-preparation.webp" alt={m.videosTitle} loading="lazy" />
      </div>
      <div class="stack" data-reveal style="--reveal-delay:120ms;">
        <p class="kicker">{m.videosTitle}</p>
        <h2 class="section-title">{m.videosTitle}</h2>
        <p class="lead">{m.videosDesc}</p>
        <a class="btn" href={path(lang, "videos")}>{m.videosButton}</a>
      </div>
    </div>
  </section>
</Base>
