---
import Base from "../../layouts/Base.astro";
import PageHero from "../PageHero.astro";
import MaplusLinesGrid from "../MaplusLinesGrid.astro";
import { t, path, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const m = tr.maplus;
---

<Base lang={lang} current="maplus">
  <PageHero
    eyebrow={m.kicker}
    title="MAPLUS"
    lead={m.intro}
    metaLeft={lang === "no" ? "OFFISIELL NORSK DISTRIBUTØR" : "OFFICIAL NORWEGIAN DISTRIBUTOR"}
    metaRight={lang === "no" ? "SKI · SYKKEL · TEKSTIL" : "SKI · BIKE · TEXTILE"}
  />

  <!-- Quick CTA to full catalog -->
  <section style="padding-block: 0 clamp(2rem,4vw,3rem);">
    <div class="container container--wide">
      <a class="btn btn--accent" href={`${path(lang, "maplus")}/${lang === "no" ? "produkter" : "products"}`}>
        {lang === "no" ? "Se hele MAPLUS-katalogen" : "Browse the full MAPLUS catalog"}
        <span style="margin-left:0.5rem; font-size:0.85rem; opacity:0.85;">323 →</span>
      </a>
    </div>
  </section>

  <!-- Brand story (editorial layout, parallels home story) -->
  <section class="story" style="padding-top:0;">
    <div class="container container--wide">
      <p class="eyebrow" style="margin-bottom:clamp(2rem,4vw,3rem);" data-reveal>{m.brandKicker}</p>
      <div class="story__inner">
        <h2 class="story__quote" data-reveal>{m.brandTitle}</h2>
        <div class="story__aside" data-reveal style="--reveal-delay:120ms;">
          <p>{m.brandBody1}</p>
          <p>{m.brandBody2}</p>
          <dl class="facts" style="margin-top:1.4rem;">
            {
              m.facts.map((f) => {
                const num = f.value.match(/^(\d+)(.*)$/);
                return (
                  <div class="fact">
                    {num ? (
                      <dt data-count={num[1]} data-suffix={num[2]}>{f.value}</dt>
                    ) : (
                      <dt>{f.value}</dt>
                    )}
                    <dd>{f.label}</dd>
                  </div>
                );
              })
            }
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Wide showcase of the actual MAPLUS wax range -->
  <section style="padding-block: 0 clamp(3rem,6vw,5rem);">
    <figure class="showcase" data-reveal>
      <img src="/images/maplus/wax-blocks.jpg" alt="MAPLUS racing wax application" loading="lazy" />
      <figcaption>MAPLUS · Race service</figcaption>
    </figure>
  </section>

  <!-- Official MAPLUS product lines (mirrors maplus.it) -->
  <section style="padding-block: clamp(3rem,6vw,5rem) 0;">
    <div class="container container--wide">
      <p class="eyebrow" data-reveal>{m.productsKicker}</p>
      <h2 class="display" style="margin-top:1.4rem; margin-bottom:clamp(2rem,4vw,3rem);" data-reveal>{lang === "no" ? "Produktserier" : "Product lines"}</h2>
      <MaplusLinesGrid lang={lang} />
    </div>
  </section>

  <!-- Editorial photo strip: race service in action -->
  <section style="padding-block: clamp(3rem,6vw,5rem) 0;">
    <div class="container container--wide">
      <p class="eyebrow" data-reveal>{lang === "no" ? "Race service" : "Race service"}</p>
      <h2 class="display" style="margin-top:1.4rem; margin-bottom:clamp(2rem,4vw,3rem);" data-reveal>{lang === "no" ? "Fra verkstedet" : "From the workshop"}</h2>
      <div class="photo-strip">
        <figure data-reveal><img src="/images/maplus/powder-pour.jpg" alt="MAPLUS racing powder" loading="lazy" /></figure>
        <figure data-reveal style="--reveal-delay:80ms;"><img src="/images/maplus/factory.jpg" alt="MAFLON factory" loading="lazy" /></figure>
        <figure data-reveal style="--reveal-delay:160ms;"><img src="/images/maplus/iron-drip.jpg" alt="Hot wax application" loading="lazy" /></figure>
      </div>
    </div>
  </section>

  <!-- Athletes: MAPLUS on the World Cup -->
  <section style="padding-block: clamp(3rem,6vw,5rem) 0;">
    <div class="container container--wide">
      <p class="eyebrow" data-reveal>{lang === "no" ? "Utøvere" : "Athletes"}</p>
      <h2 class="display" style="margin-top:1.4rem;" data-reveal>{lang === "no" ? "MAPLUS i verdenscupen" : "MAPLUS on the World Cup"}</h2>
      <p class="lead" style="margin-top:1rem; margin-bottom:clamp(2rem,4vw,3rem);" data-reveal>{lang === "no" ? "Produktene utvikles og testes sammen med utøvere på øverste internasjonale nivå." : "The products are developed and tested with athletes at the highest international level."}</p>
      <div class="athletes">
        <div class="athlete" data-reveal>
          <img src="/images/maplus/hero-pellegrino.jpg" alt="Federico Pellegrino" loading="lazy" style="object-position: 30% center;" />
          <div class="athlete__body">
            <div class="athlete__name">Federico Pellegrino</div>
            <div class="athlete__meta">{lang === "no" ? "Langrenn · Verdensmester i sprint" : "Cross-country · World sprint champion"}</div>
          </div>
        </div>
        <div class="athlete" data-reveal style="--reveal-delay:100ms;">
          <img src="/images/maplus/casse-lab.jpg" alt="Mattia Casse" loading="lazy" />
          <div class="athlete__body">
            <div class="athlete__name">Mattia Casse</div>
            <div class="athlete__meta">{lang === "no" ? "Alpint · Verdenscupvinner i utfor" : "Alpine · World Cup downhill winner"}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Videos CTA on dark band -->
  <section class="pros" style="padding-block: clamp(4rem,8vw,6rem);">
    <div class="container container--wide">
      <p class="eyebrow eyebrow--light" data-reveal>{m.videosTitle}</p>
      <div class="pros__head" style="margin-top:1.6rem;">
        <h2 class="pros__title" data-reveal>{m.videosTitle}</h2>
        <div class="pros__intro" data-reveal style="--reveal-delay:120ms;">
          <p>{m.videosDesc}</p>
          <a class="btn btn--light" style="margin-top:1.5rem;" href={path(lang, "videos")}>{m.videosButton}</a>
        </div>
      </div>
    </div>
  </section>
</Base>
