---
import Base from "../../layouts/Base.astro";
import PageHero from "../PageHero.astro";
import { t, path, CATALOGS, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const m = tr.maplus;

// Category tiles now go to the in-site product browser (filtered).
// PDF catalogs are kept as a secondary "download" option below.
const productsBase = `${path(lang, "maplus")}/${lang === "no" ? "produkter" : "products"}`;
const cats = [
  { title: m.catSki, desc: m.catSkiDesc, img: "/images/ski-1.webp", href: productsBase, cta: lang === "no" ? "Se produkter" : "View products" },
  { title: m.catBike, desc: m.catBikeDesc, img: "/images/bike-care.jpg", href: `${productsBase}?line=bike`, cta: lang === "no" ? "Se produkter" : "View products" },
  { title: m.catTextile, desc: m.catTextileDesc, img: "/images/textile-care.jpg", href: `${productsBase}?line=textile`, cta: lang === "no" ? "Se produkter" : "View products" },
];
---

<Base lang={lang} current="maplus">
  <PageHero
    eyebrow={m.kicker}
    title="MAPLUS"
    lead={m.intro}
    metaLeft={lang === "no" ? "OFFISIELL NORSK DISTRIBUTØR" : "OFFICIAL NORWEGIAN DISTRIBUTOR"}
    metaRight={lang === "no" ? "SKI · SYKKEL · TEKSTIL" : "SKI · BIKE · TEXTILE"}
  />

  <!-- Quick CTA to full catalog -->
  <section style="padding-block: 0 clamp(2rem,4vw,3rem);">
    <div class="container container--wide">
      <a class="btn btn--accent" data-magnetic href={`${path(lang, "maplus")}/${lang === "no" ? "produkter" : "products"}`}>
        {lang === "no" ? "Se hele MAPLUS-katalogen" : "Browse the full MAPLUS catalog"}
        <span style="margin-left:0.5rem; font-family:var(--font-mono); font-size:0.72rem; opacity:0.85;">323 →</span>
      </a>
    </div>
  </section>

  <!-- Brand story (editorial layout, parallels home story) -->
  <section class="story" style="padding-top:0;">
    <div class="container container--wide">
      <p class="eyebrow" style="margin-bottom:clamp(2rem,4vw,3rem);" data-reveal>{m.brandKicker}</p>
      <div class="story__inner">
        <h2 class="story__quote" data-reveal>{m.brandTitle}</h2>
        <div class="story__aside" data-reveal style="--reveal-delay:120ms;">
          <p>{m.brandBody1}</p>
          <p>{m.brandBody2}</p>
          <dl class="facts" style="margin-top:1.4rem;">
            {
              m.facts.map((f) => {
                const num = f.value.match(/^(\d+)(.*)$/);
                return (
                  <div class="fact">
                    {num ? (
                      <dt data-count={num[1]} data-suffix={num[2]}>{f.value}</dt>
                    ) : (
                      <dt>{f.value}</dt>
                    )}
                    <dd>{f.label}</dd>
                  </div>
                );
              })
            }
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Wide showcase of the actual MAPLUS wax range -->
  <section style="padding-block: 0 clamp(3rem,6vw,5rem);">
    <figure class="showcase showcase--product" data-reveal>
      <img src="/images/racing-preparation.webp" alt="MAPLUS Xcelerate Pro racing wax line" loading="lazy" />
      <figcaption>MAPLUS · Xcelerate Pro racing line</figcaption>
    </figure>
  </section>

  <!-- Category tiles (cinematic, same as home) -->
  <section style="padding-block: clamp(3rem,6vw,5rem) 0;">
    <div class="container container--wide">
      <p class="eyebrow" data-reveal>{m.productsKicker}</p>
      <h2 class="display" style="margin-top:1.4rem; margin-bottom:clamp(2rem,4vw,3rem);" data-reveal>{`${m.catSki} · ${m.catBike} · ${m.catTextile}`}</h2>
    </div>
    <div class="cat-grid">
      {
        cats.map((c, i) => (
          <a class="cat-tile" href={c.href} data-cursor={lang === "no" ? "Utforsk" : "Explore"} data-reveal style={`--reveal-delay:${i * 80}ms;`}>
            <img class="cat-tile__img" src={c.img} alt={c.title} loading="lazy" />
            <div class="cat-tile__body">
              <span class="cat-tile__num">{String(i + 1).padStart(2, "0")} / {String(cats.length).padStart(2, "0")}</span>
              <h3 class="cat-tile__name">{c.title}</h3>
              <span class="cat-tile__brand">{c.cta}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Videos CTA on dark band -->
  <section class="pros" style="padding-block: clamp(4rem,8vw,6rem);">
    <div class="container container--wide">
      <p class="eyebrow eyebrow--light" data-reveal>{m.videosTitle}</p>
      <div class="pros__head" style="margin-top:1.6rem;">
        <h2 class="pros__title" data-reveal>{m.videosTitle}</h2>
        <div class="pros__intro" data-reveal style="--reveal-delay:120ms;">
          <p>{m.videosDesc}</p>
          <a class="btn btn--light" data-magnetic style="margin-top:1.5rem;" href={path(lang, "videos")}>{m.videosButton}</a>
        </div>
      </div>
    </div>
  </section>
</Base>
