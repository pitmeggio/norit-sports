---
import Base from "../../layouts/Base.astro";
import PageHero from "../PageHero.astro";
import { t, VIDEOS, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const v = tr.videos;

const categories = Array.from(new Set(VIDEOS.map((x) => x.category)));
---

<Base lang={lang} current="videos">
  <PageHero
    eyebrow={v.kicker}
    title={v.kicker}
    lead={v.intro}
    metaLeft={`${VIDEOS.length} ${lang === "no" ? "VIDEOER" : "VIDEOS"}`}
    metaRight={lang === "no" ? "MAPLUS · BRUKSMETODER" : "MAPLUS · APPLICATION METHODS"}
  />

  <section class="section" style="padding-top:0;">
    <div class="container container--wide">
      <div class="filters" role="group" aria-label="Filter" style="margin-top:0;">
        <button class="filter" data-filter="all" aria-pressed="true">{v.all}</button>
        {
          categories.map((c) => (
            <button class="filter" data-filter={c} aria-pressed="false">
              {v.categories[c]}
            </button>
          ))
        }
      </div>

      <div class="grid grid--3" style="margin-top:2.5rem;" id="video-grid">
        {
          VIDEOS.map((item) => (
            <article class="video-card" data-category={item.category} data-reveal>
              <div class="video-card__frame">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${item.id}`}
                  title={item.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                />
              </div>
              <div class="video-card__body">
                <h3>{item.title}</h3>
                <span class="video-card__cat">{v.categories[item.category]}</span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Base>

<script>
  document.addEventListener("astro:page-load", () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter");
    const cards = document.querySelectorAll<HTMLElement>("#video-grid [data-category]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.dataset.filter;
        buttons.forEach((b) => b.setAttribute("aria-pressed", (b === btn).toString()));
        cards.forEach((c) => {
          const show = f === "all" || c.dataset.category === f;
          c.style.display = show ? "" : "none";
        });
      });
    });
  });
</script>
