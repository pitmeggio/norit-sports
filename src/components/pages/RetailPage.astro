---
import Base from "../../layouts/Base.astro";
import { t, path, RETAILERS, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const r = tr.retail;
---

<Base lang={lang} current="retail">
  <section class="section">
    <div class="container">
      <p class="kicker" data-reveal>{r.kicker}</p>
      <h1 class="section-title" style="margin-top:0.6rem;" data-reveal>{r.becomeTitle}</h1>
      <p class="lead" style="margin-top:1rem;" data-reveal>{r.intro}</p>

      <div class="split split--offset" style="margin-top:clamp(2.5rem,5vw,4rem);">
        <div class="stack" data-reveal>
          <p class="kicker">{r.becomeKicker}</p>
          <h2 class="section-title">{r.becomeWhy}</h2>
          <p class="lead">{r.becomeBody}</p>
          <ul class="ticks" style="margin-top:0.4rem;">
            {r.points.map((p) => <li>{p}</li>)}
          </ul>
          <a class="btn" href={path(lang, "contact")} style="margin-top:0.6rem;">{r.cta}</a>
        </div>
        <div class="split__media fx-mono" data-reveal style="--reveal-delay:120ms;">
          <img src="/images/ski-1.webp" alt="" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-alt">
    <div class="container">
      <p class="kicker" data-reveal>{r.kicker}</p>
      <h2 class="section-title" style="margin-top:0.6rem;" data-reveal>{r.whereTitle}</h2>

      {
        RETAILERS.length > 0 ? (
          <div class="grid grid--3" style="margin-top:2.5rem;">
            {RETAILERS.map((shop, i) => (
              <article class="retailer" data-reveal style={`--reveal-delay:${i * 80}ms;`}>
                <h3>{shop.name}</h3>
                <p class="retailer__city">{shop.city}</p>
                {shop.url && (
                  <a class="card__cta" href={shop.url} target="_blank" rel="noopener">
                    {r.visit}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                )}
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state" data-reveal>
            <p class="lead">{r.whereEmpty}</p>
            <a class="btn btn--ghost" href={path(lang, "contact")}>{r.cta}</a>
          </div>
        )
      }
    </div>
  </section>
</Base>
