---
import Base from "../../layouts/Base.astro";
import PageHero from "../PageHero.astro";
import { t, path, RETAILERS, type Lang } from "../../i18n/content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = t[lang];
const r = tr.retail;
---

<Base lang={lang} current="retail">
  <PageHero
    eyebrow={r.kicker}
    title={r.becomeTitle}
    lead={r.intro}
    metaLeft={lang === "no" ? "FOR BUTIKKER" : "FOR STORES"}
    metaRight={lang === "no" ? "MAPLUS · EFB SPORT" : "MAPLUS · EFB SPORT"}
  />

  <!-- Why partner — editorial story layout -->
  <section class="story" style="padding-top:0;">
    <div class="container container--wide">
      <p class="eyebrow" style="margin-bottom:clamp(2rem,4vw,3rem);" data-reveal>{r.becomeKicker}</p>
      <div class="story__inner">
        <h2 class="story__quote" data-reveal>{r.becomeWhy}</h2>
        <div class="story__aside" data-reveal style="--reveal-delay:120ms;">
          <p>{r.becomeBody}</p>
          <ul class="ticks" style="margin-top:0.4rem;">
            {r.points.map((p) => <li>{p}</li>)}
          </ul>
          <a class="btn" style="margin-top:0.8rem;" href={path(lang, "contact")}>{r.cta}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Where to buy section (retailers list / empty state) -->
  <section class="section bg-alt">
    <div class="container container--wide">
      <p class="eyebrow" data-reveal>{r.kicker}</p>
      <h2 class="display" style="margin-top:1.4rem;" data-reveal>{r.whereTitle}</h2>

      {
        RETAILERS.length > 0 ? (
          <div class="grid grid--3" style="margin-top:2.5rem;">
            {RETAILERS.map((shop, i) => (
              <article class="retailer" data-reveal style={`--reveal-delay:${i * 80}ms;`}>
                <h3>{shop.name}</h3>
                <p class="retailer__city">{shop.city}</p>
                {shop.url && (
                  <a class="card__cta" href={shop.url} target="_blank" rel="noopener">
                    {r.visit}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                )}
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state" data-reveal style="margin-top:2.5rem;">
            <p class="lead">{r.whereEmpty}</p>
            <a class="btn btn--ghost" href={path(lang, "contact")}>{r.cta}</a>
          </div>
        )
      }
    </div>
  </section>
</Base>
